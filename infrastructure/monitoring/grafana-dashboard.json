{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": "Prometheus",
        "enable": true,
        "expr": "changes(kube_deployment_status_observed_generation{namespace=\"seva\"}[1m]) > 0",
        "iconColor": "#F97316",
        "name": "Deployments",
        "titleFormat": "Deployment: {{ deployment }}"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "API Overview",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Request Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"seva-backend\"}[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Error Rate (5xx)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"seva-backend\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"seva-backend\"}[5m]))",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "P95 Latency",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"seva-backend\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Users (5m)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(seva_active_users_total)",
          "legendFormat": "users"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 6,
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"seva-backend\"}[5m])) by (handler)",
          "legendFormat": "{{ handler }}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 7,
      "title": "Latency by Endpoint (P95)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"seva-backend\"}[5m])) by (le, handler))",
          "legendFormat": "{{ handler }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 10,
      "title": "Database & Redis",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 11,
      "title": "DB Connection Pool",
      "type": "timeseries",
      "targets": [
        {
          "expr": "seva_db_pool_active_connections",
          "legendFormat": "Active"
        },
        {
          "expr": "seva_db_pool_idle_connections",
          "legendFormat": "Idle"
        },
        {
          "expr": "seva_db_pool_max_connections",
          "legendFormat": "Max"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "id": 12,
      "title": "Redis Memory",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Used"
        },
        {
          "expr": "redis_memory_max_bytes",
          "legendFormat": "Max"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 13,
      "title": "Redis Connections",
      "type": "timeseries",
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Connected clients"
        },
        {
          "expr": "rate(redis_commands_processed_total[5m])",
          "legendFormat": "Commands/s"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 20,
      "title": "Business Metrics",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "id": 21,
      "title": "Jobs Created / Completed",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "sum(increase(seva_jobs_created_total[1h]))",
          "legendFormat": "Created"
        },
        {
          "expr": "sum(increase(seva_jobs_completed_total[1h]))",
          "legendFormat": "Completed"
        },
        {
          "expr": "sum(increase(seva_jobs_cancelled_total[1h]))",
          "legendFormat": "Cancelled"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "id": 22,
      "title": "User Registrations",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(seva_registrations_total[1h])) by (role)",
          "legendFormat": "{{ role }}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "id": 23,
      "title": "OTP Success Rate",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      },
      "targets": [
        {
          "expr": "sum(rate(seva_otp_verified_total[5m])) / sum(rate(seva_otp_sent_total[5m]))",
          "legendFormat": "Success rate"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["seva", "production"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "Asia/Kolkata",
  "title": "Seva Platform - Production Dashboard",
  "uid": "seva-prod-overview",
  "version": 1
}
