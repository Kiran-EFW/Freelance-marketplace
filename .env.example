# =============================================================================
# Seva Platform — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Application ---
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=debug
LOG_FORMAT=text

# --- Database (PostgreSQL + PostGIS) ---
DATABASE_URL=postgres://seva:seva_dev@localhost:5432/seva?sslmode=disable

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Meilisearch ---
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=seva_meili_dev_key

# --- Authentication ---
JWT_SECRET=change-me-in-production
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3

# --- SMS Provider ---
# Options: mock, twilio, msg91
SMS_PROVIDER=mock
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=

# --- Payment Provider ---
# Options: mock, razorpay, stripe
PAYMENT_PROVIDER=mock
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- File Storage (S3-compatible / Cloudflare R2) ---
# STORAGE_ENDPOINT=
# STORAGE_BUCKET=seva-dev-uploads
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_CDN_URL=

# --- WhatsApp (optional) ---
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# --- Push Notifications (Firebase) ---
# FIREBASE_CREDENTIALS_FILE=
# or
# FIREBASE_PROJECT_ID=

# --- Web Frontend ---
PUBLIC_API_URL=http://localhost:8080
ORIGIN=http://localhost:3000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Matching ---
MATCH_RADIUS_KM=25
MATCH_MAX_PROVIDERS=10

# --- Trust Score Weights ---
TRUST_RATING_WEIGHT=0.3
TRUST_COMPLETION_WEIGHT=0.25
TRUST_RESPONSE_WEIGHT=0.2
TRUST_KYC_WEIGHT=0.15
TRUST_TENURE_WEIGHT=0.1

# --- Default Jurisdiction ---
DEFAULT_JURISDICTION=IN
DEFAULT_CURRENCY=INR
DEFAULT_LOCALE=en-IN

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=10

# --- Feature Flags ---
FEATURE_AI_BOOKING=false
FEATURE_PHOTO_ANALYSIS=false
FEATURE_VOICE_IVR=false
FEATURE_ROUTE_OPTIMIZATION=true
