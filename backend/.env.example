# Server
SERVER_PORT=8080
ENVIRONMENT=dev  # dev | staging | prod

# PostgreSQL (with PostGIS)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/seva?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRY=24h

# SMS Provider (twilio | msg91 | noop)
SMS_PROVIDER=noop
SMS_API_KEY=

# Object Storage (S3-compatible)
STORAGE_BUCKET=seva-uploads
STORAGE_REGION=ap-south-1

# AI Services (at least one chat provider recommended)
CLAUDE_API_KEY=              # Anthropic Claude API key (preferred)
OPENAI_API_KEY=              # OpenAI API key (used if CLAUDE_API_KEY is not set)
GOOGLE_VISION_CREDENTIALS=   # Google Vision API key or credentials JSON
GOOGLE_TRANSLATE_CREDENTIALS= # Google Translate API key or credentials JSON

# Rate Limiting (per second per IP, defaults: dev=100, prod=30)
# RATE_LIMIT_MAX=100
